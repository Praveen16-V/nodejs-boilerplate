# Server Configuration
NODE_ENV=development
PORT=3000
HOST=localhost

# Security
JWT_SECRET=dev-jwt-secret-key-for-local-development-only
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# Database
MONGODB_URI=mongodb://localhost:27017/secure-app
MONGODB_TEST_URI=mongodb://localhost:27017/secure-app-test

# Session
SESSION_SECRET=dev-session-secret-for-local-development-only

# CORS
CORS_ORIGIN=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
LOG_FILE=logs/app.log

# API Keys
API_KEY_ENCRYPTION_SECRET=dev-api-key-encryption-secret-for-local-only
